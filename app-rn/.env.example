# Backend
EXPO_PUBLIC_BACKEND_URL=http://localhost:8080

# Google OIDC — Web OAuth Client ID (audience for ID tokens; backend verifies against this).
# Same value used as @react-native-google-signin's webClientId.
# Register one Web client in Google Cloud Console and reuse across all namespaces.
EXPO_PUBLIC_GOOGLE_OAUTH_WEB_CLIENT_ID=
