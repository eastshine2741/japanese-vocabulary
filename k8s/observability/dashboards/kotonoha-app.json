{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "kotonoha-app",
  "title": "Kotonoha — App Metrics",
  "tags": ["kotonoha"],
  "timezone": "Asia/Seoul",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Golden-path APIs",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP p95 latency by uri",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 1, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (uri, le) (rate(http_server_requests_seconds_bucket{uri!=\"UNKNOWN\",uri!=\"\",uri!~\"/actuator.*\"}[5m])))",
          "legendFormat": "{{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 5}
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP 5xx rate by uri",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 1, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{outcome=\"SERVER_ERROR\",uri!=\"UNKNOWN\",uri!=\"\",uri!~\"/actuator.*\"}[5m]))",
          "legendFormat": "{{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 5}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Translation pipeline",
      "gridPos": {"x": 0, "y": 9, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Pending backlog",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 10, "w": 6, "h": 5},
      "targets": [
        {
          "refId": "A",
          "expr": "max(kotonoha_lyric_translation_pending)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 50}
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Processing",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 6, "y": 10, "w": 6, "h": 5},
      "targets": [
        {
          "refId": "A",
          "expr": "max(kotonoha_lyric_translation_processing)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue", "value": null}
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Failed (terminal)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 10, "w": 6, "h": 5},
      "targets": [
        {
          "refId": "A",
          "expr": "max(kotonoha_lyric_translation_failed)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "Cache hit rate (1h)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 18, "y": 10, "w": 6, "h": 5},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(kotonoha_song_search_cache_total{result=\"hit\"}[1h])) / sum(rate(kotonoha_song_search_cache_total{result=~\"hit|miss\"}[1h]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.3},
              {"color": "green", "value": 0.6}
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Translation duration percentiles",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 15, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(kotonoha_lyric_translation_duration_seconds_bucket{outcome=\"success\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(kotonoha_lyric_translation_duration_seconds_bucket{outcome=\"success\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(kotonoha_lyric_translation_duration_seconds_bucket{outcome=\"success\"}[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 5}
        }
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Translation throughput by outcome (per min)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 15, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "60 * sum by (outcome) (rate(kotonoha_lyric_translation_duration_seconds_count[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 20, "stacking": {"mode": "normal"}}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["sum", "lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Gemini",
      "gridPos": {"x": 0, "y": 23, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Gemini call rate by call (per min)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "60 * sum by (call, outcome) (rate(kotonoha_gemini_call_duration_seconds_count[5m]))",
          "legendFormat": "{{call}} / {{outcome}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 5}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Gemini p95 duration by call",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (call, le) (rate(kotonoha_gemini_call_duration_seconds_bucket{outcome=\"success\"}[5m])))",
          "legendFormat": "{{call}} p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 5}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Gemini tokens / min (call × model × kind)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 32, "w": 24, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "60 * sum by (call, model, kind) (rate(kotonoha_gemini_tokens_total[5m]))",
          "legendFormat": "{{call}} / {{model}} / {{kind}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 5}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["sum", "lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "Song search cache",
      "gridPos": {"x": 0, "y": 40, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Cache ops by result (per min)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 41, "w": 24, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "60 * sum by (result) (rate(kotonoha_song_search_cache_total[5m]))",
          "legendFormat": "{{result}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 20, "stacking": {"mode": "normal"}}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["sum", "lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 40,
      "type": "row",
      "title": "External APIs",
      "gridPos": {"x": 0, "y": 49, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Request rate by api (per min)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 50, "w": 8, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "60 * sum by (api) (rate(http_client_requests_seconds_count[5m]))",
          "legendFormat": "{{api}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 5}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "p95 latency by api",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 8, "y": 50, "w": 8, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (api, le) (rate(http_client_requests_seconds_bucket[5m])))",
          "legendFormat": "{{api}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 5}
        }
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      }
    },
    {
      "id": 43,
      "type": "timeseries",
      "title": "Error rate by api (non-SUCCESS, per min)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 16, "y": 50, "w": 8, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "60 * sum by (api, outcome) (rate(http_client_requests_seconds_count{outcome!=\"SUCCESS\"}[5m]))",
          "legendFormat": "{{api}} / {{outcome}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 5}
