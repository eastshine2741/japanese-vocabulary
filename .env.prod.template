# Production environment template
# Copy to .env.prod and fill in values. .env.prod is gitignored.
# Used by: DEPLOY_ENV=prod ./deploy.sh

# --- MySQL ---
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=

# --- Auth & external APIs ---
JWT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
YOUTUBE_API_KEY=
GEMINI_API_KEY=

# --- GitHub Container Registry (ghcr.io) ---
# PAT scopes required: write:packages, read:packages
GHCR_USERNAME=eastshine
GHCR_TOKEN=
