# Copy values into your shell profile, crontab wrapper, or a private env file.
# Do not commit real tokens.

SENTRY_AUTH_TOKEN=
SENTRY_ORG=
# Sentry numeric project id used by the organization issues API.
SENTRY_PROJECT=
# Optional comma-separated alternatives. Each value becomes a repeated query param.
# SENTRY_PROJECTS=123,456
SENTRY_ENVIRONMENT=production
# SENTRY_ENVIRONMENTS=production,staging

DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
SENTRY_TRIAGE_HANDLED_EMOJI=✅
SENTRY_TRIAGE_DISCORD_FALLBACK=0

# Optional. The runner auto-detects the repo root when invoked from this checkout.
# SENTRY_TRIAGE_REPO_DIR=/absolute/path/to/this/repo
SENTRY_TRIAGE_REPLAY_DAYS=7
SENTRY_TRIAGE_LIMIT=20
SENTRY_TRIAGE_MAX_PAGES=5
SENTRY_TRIAGE_DISCORD_HISTORY_LIMIT=50
SENTRY_TRIAGE_DISCORD_COMPLETION_LOOKUP_PAGES=5
SENTRY_TRIAGE_PR_MAX_CHANGED_FILES=8
SENTRY_TRIAGE_PR_MAX_DIFF_LINES=400

# Optional overrides
# XDG_STATE_HOME=$HOME/.local/state
# SENTRY_TRIAGE_STATE_FILE=$HOME/.local/state/kotonoha-sentry-triage/processed.json
# SENTRY_TRIAGE_LOG_FILE=$HOME/.local/state/kotonoha-sentry-triage/logs/sentry-triage-$(date +%Y%m%d).log
# SENTRY_TRIAGE_COMMAND_LOG=/tmp/kotonoha-sentry-triage-commands.log
